generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext, pg_trgm]
}

model User {
  id                 String                @id @default(cuid())
  discordId          String                @unique @map("discord_id")
  lastfmUsername     String?               @map("lastfm_username") @db.Citext
  lastfmSessionKey   String?               @map("lastfm_session_key")
  lastfmRequestToken String?               @map("lastfm_request_token")
  discogsUsername    String?               @unique @map("discogs_username") @db.Citext
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  settings           Json?
  lastAlbumRoll      DateTime?             @map("last_album_roll")
  albumRolls         Int                   @default(0) @map("album_rolls")
  crownHistory       CrownHistory[]
  crowns             Crown[]
  friendedBy         Friend[]              @relation("UserFriendedBy")
  friends            Friend[]              @relation("UserFriends")
  guilds             GuildMember[]
  importJobs         ImportJob[]
  albumCollection    UserAlbumCollection[]
  artistCollection   UserArtistCollection[]
  userAlbums         UserAlbum[]
  userArtists        UserArtist[]
  gameProfile        UserGameProfile?
  userPlays          UserPlay[]
  userTracks         UserTrack[]
  activeTours        ActiveTour[]
  raidContributions  RaidContribution[]

  @@index([discordId])
  @@index([lastfmUsername])
  @@index([lastfmSessionKey])
  @@map("users")
}

model Guild {
  id        String        @id @default(cuid())
  guildId   String        @unique @map("guild_id")
  createdAt DateTime      @default(now())
  crowns    Crown[]
  members   GuildMember[]

  @@index([guildId])
  @@map("guilds")
}

model GuildMember {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  userId  String @map("user_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
  @@map("guild_members")
}

model Artist {
  id             String       @id @default(cuid())
  name           String       @unique @db.Citext
  mbid           String?      @unique
  countryCode    String?      @map("country_code")
  type           String?
  gender         String?
  disambiguation String?
  lastfmUrl      String?      @map("lastfm_url")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  albums         Album[]
  links          ArtistLink[]
  tags           ArtistTag[]
  crowns         Crown[]
  tracks         Track[]
  userAlbums     UserAlbum[]
  collectedBy    UserArtistCollection[]
  userArtists    UserArtist[]
  userPlays      UserPlay[]
  userTracks     UserTrack[]
  activeTours    ActiveTour[]
  raidBosses     RaidBoss[]

  @@map("artists")
}

model ArtistLink {
  id        String   @id @default(cuid())
  artistId  String   @map("artist_id")
  type      String
  url       String
  username  String?
  createdAt DateTime @default(now())
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, type])
  @@map("artist_links")
}

model Track {
  id         String      @id @default(cuid())
  name       String      @db.Citext
  artistId   String      @map("artist_id")
  mbid       String?     @unique
  duration   Int?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  artist     Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  userPlays  UserPlay[]
  userTracks UserTrack[]

  @@unique([artistId, name])
  @@map("tracks")
}

model Album {
  id          String                @id @default(cuid())
  name        String                @db.Citext
  artistId    String                @map("artist_id")
  mbid        String?               @unique
  imageLarge  String?               @map("image_large")
  imageMedium String?               @map("image_medium")
  imageSmall  String?               @map("image_small")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  artist      Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  marketItems MarketItem[]
  collections UserAlbumCollection[]
  userAlbums  UserAlbum[]
  userPlays   UserPlay[]

  @@unique([artistId, name])
  @@map("albums")
}

model UserAlbumCollection {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  albumId   String   @map("album_id")
  rarity      String   @default("COMMON")
  variant     String   @default("NORMAL")
  polishLevel Int      @default(0) @map("polish_level")
  claimedAt   DateTime @default(now()) @map("claimed_at")
  masteryXp   Int      @default(0) @map("mastery_xp")
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@map("user_album_collections")
}

model UserGameProfile {
  userId          String    @id @map("user_id")
  vinylScraps     Int       @default(0) @map("vinyl_scraps")
  wishlist        String[]  @default([])
  lastDaily       DateTime? @map("last_daily")
  collectionValue Int       @default(0) @map("collection_value")
  quests          Json?
  questDate       DateTime? @map("quest_date")
  badges          String[]  @default([])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_game_profiles")
}

model UserArtistCollection {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  artistId    String   @map("artist_id")
  rarity      String   @default("COMMON")
  variant     String   @default("NORMAL")
  polishLevel Int      @default(0) @map("polish_level")
  masteryXp   Int      @default(0) @map("mastery_xp")
  claimedAt   DateTime @default(now()) @map("claimed_at")
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId, rarity, variant])
  @@map("user_artist_collections")
}

model MarketItem {
  id        String   @id @default(cuid())
  albumId   String   @map("album_id")
  price     Int
  rarity    String
  expiresAt DateTime @map("expires_at")
  isSold    Boolean  @default(false) @map("is_sold")
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("market_items")
}

model UserArtist {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  artistName String  @map("artist_name") @db.Citext
  playcount  Int     @default(0)
  artistId   String? @map("artist_id")
  artist     Artist? @relation(fields: [artistId], references: [id])
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistName])
  @@index([userId])
  @@index([artistId])
  @@index([artistName])
  @@map("user_artists")
}

model UserTrack {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  artistName String  @map("artist_name") @db.Citext
  trackName  String  @map("track_name") @db.Citext
  playcount  Int     @default(0)
  duration   Int?    @map("duration")
  artistId   String? @map("artist_id")
  trackId    String? @map("track_id")
  artist     Artist? @relation(fields: [artistId], references: [id])
  track      Track?  @relation(fields: [trackId], references: [id])
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistName, trackName])
  @@index([userId])
  @@index([trackId])
  @@index([trackName])
  @@map("user_tracks")
}

model UserAlbum {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  artistName String  @map("artist_name") @db.Citext
  albumName  String  @map("album_name") @db.Citext
  playcount  Int     @default(0)
  albumId    String? @map("album_id")
  artistId   String? @map("artist_id")
  album      Album?  @relation(fields: [albumId], references: [id])
  artist     Artist? @relation(fields: [artistId], references: [id])
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistName, albumName])
  @@index([userId])
  @@index([albumId])
  @@index([albumName])
  @@map("user_albums")
}

model UserPlay {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  artistName String   @map("artist_name") @db.Citext
  trackName  String   @map("track_name") @db.Citext
  albumName  String?  @map("album_name") @db.Citext
  timePlayed DateTime @map("time_played")
  albumId    String?  @map("album_id")
  artistId   String?  @map("artist_id")
  trackId    String?  @map("track_id")
  album      Album?   @relation(fields: [albumId], references: [id])
  artist     Artist?  @relation(fields: [artistId], references: [id])
  track      Track?   @relation(fields: [trackId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timePlayed, artistName, trackName])
  @@index([userId])
  @@index([trackId])
  @@index([timePlayed])
  @@map("user_plays")
}

model Crown {
  id               String   @id @default(cuid())
  guildId          String   @map("guild_id")
  artistName       String   @map("artist_name") @db.Citext
  userId           String   @map("user_id")
  playcount        Int      @default(0)
  initialPlaycount Int      @default(0) @map("initial_playcount")
  claimedAt        DateTime @default(now()) @map("claimed_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  artistId         String?  @map("artist_id")
  artist           Artist?  @relation(fields: [artistId], references: [id])
  guild            Guild    @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, artistName])
  @@index([guildId])
  @@index([userId])
  @@map("crowns")
}

model CrownHistory {
  id               String   @id @default(cuid())
  guildId          String   @map("guild_id")
  artistName       String   @map("artist_name") @db.Citext
  userId           String   @map("user_id")
  playcountAtClaim Int      @map("playcount_at_claim")
  playcountAtLoss  Int?     @map("playcount_at_loss")
  claimedAt        DateTime @map("claimed_at")
  lostAt           DateTime @default(now()) @map("lost_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId, artistName])
  @@map("crown_history")
}

model Friend {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  friend    User     @relation("UserFriendedBy", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@map("friends")
}

model ImportJob {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  source          String
  status          String        @default("PENDING")
  totalTracks     Int           @default(0)
  scrobbledTracks Int           @default(0)
  isLegacy        Boolean       @default(false) @map("is_legacy")
  lastProcessedAt DateTime?     @map("last_processed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks          ImportTrack[]

  @@map("import_jobs")
}

model ImportTrack {
  id        String    @id @default(cuid())
  jobId     String    @map("job_id")
  artist    String
  track     String
  album     String?
  timestamp Int
  processed Boolean   @default(false)
  job       ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, artist, track, timestamp])
  @@index([jobId, processed])
  @@map("import_tracks")
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique @db.Citext
  artists ArtistTag[]

  @@map("tags")
}

model ArtistTag {
  artistId String @map("artist_id")
  tagId    String @map("tag_id")
  count    Int?
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artistId, tagId])
  @@map("artist_tags")
}

model ActiveTour {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  artistId         String   @map("artist_id")
  startTime        DateTime @map("start_time")
  initialScrobbles Int      @map("initial_scrobbles")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
  @@map("active_tours")
}

model RaidBoss {
  id               String   @id @default(cuid())
  guildId          String?  @map("guild_id")
  artistId         String   @map("artist_id")
  targetScrobbles  Int      @map("target_scrobbles")
  currentScrobbles Int      @default(0) @map("current_scrobbles")
  startTime        DateTime @default(now()) @map("start_time")
  endTime          DateTime @map("end_time")
  status           String   @default("ACTIVE") // ACTIVE, DEFEATED, FAILED
  notificationChannelId String? @map("notification_channel_id")
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  contributions    RaidContribution[]

  @@index([status])
  @@map("raid_bosses")
}

model RaidContribution {
  id         String   @id @default(cuid())
  raidId     String   @map("raid_id")
  userId     String   @map("user_id")
  scrobbles  Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")
  raid       RaidBoss @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([raidId, userId])
  @@map("raid_contributions")
}

model QueueSnapshot {
  guildId        String   @id @map("guild_id")
  voiceChannelId String   @map("voice_channel_id")
  textChannelId  String   @map("text_channel_id")
  currentTrack   String   @map("current_track") @db.Text
  tracks         String   @map("tracks") @db.Text
  positionMs     Int      @map("position_ms")
  volume         Int      @default(100) @map("volume")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("queue_snapshots")
}
